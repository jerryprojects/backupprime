# Environment variables for PRIME Project Hub Backend

# Django Settings
SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Configuration (adjust for your frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Database
# Default is SQLite3, no configuration needed
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/primedb
